<html>
<head>
    <meta charset="utf-8">
    <title>TheKawaCompany Complete API Documentation</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.5; color: #222; margin: 28px; }
        h1, h2, h3 { color: #0f4c81; }
        h1 { border-bottom: 2px solid #0f4c81; padding-bottom: 8px; }
        table { width: 100%; border-collapse: collapse; margin: 12px 0 24px; }
        th, td { border: 1px solid #cfd8e3; padding: 8px 10px; text-align: left; vertical-align: top; }
        th { background: #eef4fb; }
        code, pre { font-family: Consolas, monospace; }
